# Database
DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"

# Logto Auth
PUBLIC_LOGTO_ENDPOINT=https://your-logto-instance.logto.app
PUBLIC_LOGTO_APP_ID=your-app-id
LOGTO_APP_SECRET=your-app-secret
LOGTO_COOKIE_ENCRYPTION_KEY=a-random-string-at-least-32-characters
LOGTO_ROLE_CLAIM=roles
LOGTO_API_RESOURCE=https://your-api-resource

# App
NODE_ENV=development
ADMIN_EMAIL_WHITELIST=
ADMIN_DOMAIN_WHITELIST=dmun.de
